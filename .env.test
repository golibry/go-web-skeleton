# Local environment configuration
APP_ENV=test
APP_BASE_DIR=.
APP_LOG_LEVEL=info
APP_LOG_PATH=stdout

# Database Configuration for MariaDB Docker Container
DB_ROOT_PASSWORD=root_password
DB_DRIVER=mysql
DB_NAME=go_web_skeleton_test
DB_USER=root
DB_PASSWORD=root_password
DB_DSN=${DB_USER}:${DB_PASSWORD}@tcp(localhost:3306)/${DB_NAME}
DB_MAX_IDLE_CONNECTIONS=1
DB_MAX_OPEN_CONNECTIONS=1
DB_CONNECTION_MAX_IDLE_TIME=3m
DB_CONNECTION_MAX_LIFETIME=3m
DB_MIGRATIONS_DIR_PATH=./_examples/advanced/migrations
DB_MIGRATIONS_TABLE=migrations_executions

# Integration/e2e environment reset
TEST_RESET_DATABASE=true
# TEST_RESET_DATABASE_ALLOW_UNSAFE=true
# TEST_RESET_DATABASE_ALLOW_ANY_ENV=true
# TEST_RESET_DATABASE_ALLOW_ANY_DATABASE=true
