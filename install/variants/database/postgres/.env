APP_BASE_DIR=.
APP_ENV=loc
APP_LOG_LEVEL=info
APP_LOG_PATH=stdout

DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=app
DB_USER=app_user
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password
DB_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable
DB_MAX_IDLE_CONNECTIONS=2
DB_MAX_OPEN_CONNECTIONS=10
DB_CONNECTION_MAX_IDLE_TIME=3m
DB_CONNECTION_MAX_LIFETIME=3m
DB_MIGRATIONS_DIR_PATH=./migrations
DB_MIGRATIONS_TABLE=migrations_executions

HTTP_BIND_ADDRESS=127.0.0.1
HTTP_BIND_PORT=8080
HTTP_MAX_HEADER_BYTES=16384
HTTP_REQUEST_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
