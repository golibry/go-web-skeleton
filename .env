# Base environment configuration file
# This file serves as a default and example for environment variables
# Copy this file to .env.local or .env.{environment}.local for your specific configuration

# Application Configuration
APP_BASE_DIR=.
APP_ENV=dev
APP_LOG_LEVEL=warn
APP_LOG_PATH=stdout

# Database Configuration
# Example DSN format: user:password@tcp(localhost:3306)/dbname
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=go_web_skeleton
DB_USER=app_user
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password
DB_DSN="${DB_USER}:${DB_PASSWORD}@tcp(${DB_HOST}:${DB_PORT})/${DB_NAME}?parseTime=true&charset=utf8mb4"
DB_MAX_IDLE_CONNECTIONS=2
DB_MAX_OPEN_CONNECTIONS=10
DB_CONNECTION_MAX_IDLE_TIME=3m
DB_CONNECTION_MAX_LIFETIME=3m
DB_MIGRATIONS_DIR_PATH=./migrations

# HTTP Server Configuration
HTTP_BIND_ADDRESS=0.0.0.0
HTTP_BIND_PORT=8080
HTTP_MAX_HEADER_BYTES=16384
HTTP_REQUEST_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
